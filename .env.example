# Backend API URL
# For Android emulator use 10.0.2.2; for iOS simulator use localhost
EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Firebase config is handled via google-services.json (Android) and
# GoogleService-Info.plist (iOS) — no env vars needed for Firebase native SDK

# Subscription Configuration
EXPO_PUBLIC_SUBSCRIPTION_ENABLED=false  # Feature flag: when false, all users get full access
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=     # RevenueCat Android API key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=         # RevenueCat iOS API key
